# Sync server runtime
SYNC_SERVER_PORT=8080

# Enable Supabase storage mode
USE_SUPABASE=true

# Supabase project credentials (required when USE_SUPABASE=true)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# One-time schema initialization connection string (required for db:init command)
# Example: postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
