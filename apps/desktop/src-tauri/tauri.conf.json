{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STU-LS Desktop",
  "version": "0.1.3",
  "identifier": "com.stuls.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "STU-LS Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/Sudharmas/STU-LS/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyQTE2MkM2RTEwNUFBMkUKUldRdXFnWGh4bUtoTWhjWmxxSWE0cDNPMnphdHVXSzZrM3RGZEkrSXRmd1drZmxGVlk1d2VReTcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"]
  }
}
